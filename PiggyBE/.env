# Network mode: Để trống hoặc ghi bridge cho local
DOCKER_NETWORK_MODE=bridge

# Địa chỉ kết nối: Dùng tên service trong Docker
DB_HOST=piggy-mysql
CONSUL_HOST=piggy-consul
RABBIT_HOST=piggy-rabbitmq

# CORS: Link của React chạy npm run dev
ALLOWED_ORIGINS=http://localhost:5173

# Nginx gọi Gateway
GATEWAY_HOST=piggy-gateway